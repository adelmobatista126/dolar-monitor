# Backend .env.example
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dolar_monitor

# Server
PORT=3000

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Email (SendGrid) - Optional
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# SMS (Twilio) - Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# API
DOLAR_API_URL=https://api.exchangerate-api.com/v4/latest/USD