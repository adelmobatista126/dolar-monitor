PORT=3000
NODE_ENV=development

# APIs de Cotação
DOLAR_API_URL=https://economia.awesomeapi.com.br/json/last/USD-BRL

# Banco de Dados
DB_PATH=./data/dolar.db

# Thresholds
ALERT_THRESHOLD=0.50
CHECK_INTERVAL_MINUTES=15

# Email (SendGrid)
SENDGRID_API_KEY=sua_chave_aqui
SENDGRID_FROM_EMAIL=noreply@dolarmonitor.com.br

# SMS (Twilio)
TWILIO_ACCOUNT_SID=sua_sid_aqui
TWILIO_AUTH_TOKEN=seu_token_aqui
TWILIO_PHONE_NUMBER=+5511999999999

# JWT
JWT_SECRET=sua_chave_jwt_segura_aqui
JWT_EXPIRE=7d

# Notificações
ENABLE_EMAIL=true
ENABLE_SMS=true
ENABLE_PUSH=true
